# delu agent — environment variables
# Copy to .env and fill in your values

# Venice AI (private inference)
VENICE_API_KEY=your_venice_api_key_here

# Bankr (onchain execution on Base)
BANKR_API_KEY=your_bankr_api_key_here

# Base RPC
BASE_RPC=https://mainnet.base.org

# Chainlink price feeds (Base mainnet)
CHAINLINK_ETH_USD=0x71041dddad3595F9CEd3DcCFBe3D1F4b0a16Bb70
CHAINLINK_BTC_USD=0xCCADC697c55bbB68dc5bCdf8d3CBe83CdD4E071E

# USDC on Base
USDC_BASE=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# Agent wallet (your Base wallet address)
DELU_WALLET=your_wallet_address_here

# x402 wallet (for pay-per-call APIs)
X402_WALLET=your_x402_wallet_address_here

# The Synthesis hackathon (optional)
SYNTHESIS_API_KEY=
SYNTHESIS_PARTICIPANT_ID=
SYNTHESIS_TEAM_ID=
